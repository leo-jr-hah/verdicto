# Casper Testnet
CASPER_RPC_URL=https://node.testnet.casper.network:7777/rpc
CASPER_CHAIN_NAME=casper-test

# Account Private Key Files (absolute paths to .pem files)
DEPLOYER_PRIVATE_KEY=/path/to/deployer/secret_key.pem
AGENT_A_PRIVATE_KEY=/path/to/agent-a/secret_key.pem
AGENT_B_PRIVATE_KEY=/path/to/agent-b/secret_key.pem
ASSESSMENT_FILER_KEY=/path/to/assessment-filer/secret_key.pem

# Account Public Keys (hex)
DEPLOYER_PUBLIC_KEY=
AGENT_A_PUBLIC_KEY=
AGENT_B_PUBLIC_KEY=
FILER_PUBLIC_KEY=

# Contract Hashes (fill after Day 2 deploy)
REPUTATION_CONTRACT_HASH=
ASSESSMENT_CONTRACT_HASH=
VOTING_CONTRACT_HASH=
VERDICT_ORACLE_CONTRACT_HASH=

# CSPR.cloud
CSPRCLOUD_API_KEY=your_api_key_here
CSPRCLOUD_BASE_URL=https://api.cspr.cloud/v1

# Agent Server Ports
VALUATION_A_PORT=3001
VALUATION_B_PORT=3002
EVIDENCE_ANALYST_PORT=3003
ORCHESTRATOR_PORT=3000
WEBSOCKET_PORT=3010

# x402 Payment Protocol
# Set X402_REQUIRE_PAYMENT=true to enforce payment on all endpoints
# (localhost calls from orchestrator→agents are always allowed)
X402_REQUIRE_PAYMENT=false
X402_RECIPIENT_ADDRESS=your_deployer_account_hash

# Dashboard
VITE_ORCHESTRATOR_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3010

# Admin secret for demo/testing admin endpoints (x-admin-secret header)
# Required to access POST /api/admin/force-revalue/:loanId and GET /api/admin/loans
ADMIN_SECRET=your-admin-secret-here
